# Database Configuration
# PostgreSQL connection string for Utsav API (Supabase)

# Required - PostgreSQL connection URL
# Format: postgresql://username:password@host:port/database_name
# For Supabase, use your project's connection string from Supabase dashboard
# The password contains special characters (@ and #), so URL encode them: @ = %40, # = %23
DATABASE_URL="postgresql://postgres.yqnowtwzyxxstyverecd:Pratibimba%40%23123@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"

# JWT Configuration
# Required - Secret key for JWT token signing (use a strong random string in production)
JWT_SECRET="utsav-dev-secret-2024"
JWT_ACCESS_SECRET="utsav-access-secret-2024"
JWT_REFRESH_SECRET="utsav-refresh-secret-2024"

# Optional - JWT expiration times
JWT_ACCESS_TOKEN_EXPIRY="15m"
JWT_REFRESH_TOKEN_EXPIRY="7d"

# Optional - Direct connection parameters (alternative to DATABASE_URL)
# DATABASE_HOST="localhost"
# DATABASE_PORT="5432"
# DATABASE_NAME="utsav"
# DATABASE_USER="postgres"
# DATABASE_PASSWORD="your_password_here"

# Optional - Connection pool settings
# DATABASE_POOL_SIZE="5"
# DATABASE_CONNECTION_TIMEOUT="10"

# Optional - For production with SSL
# DATABASE_SSL="true"
# DATABASE_CA=""
# DATABASE_KEY=""
# DATABASE_CERT=""

# =============================================================================
# Payment Gateways (Nepal)
# =============================================================================

# eSewa Payment Gateway
# https://developer.esewa.com.np/
# ESEWA_MERCHANT_ID="your_esewa_merchant_id"
# ESEWA_MERCHANT_SECRET="your_esewa_merchant_secret"
# ESEWA_BASE_URL="https://esewa.com.np"

# Khalti Payment Gateway
# https://docs.khalti.com/
# KHALTI_PUBLIC_KEY="your_khalti_public_key"
# KHALTI_SECRET_KEY="your_khalti_secret_key"

# =============================================================================
# SMS Gateway
# =============================================================================

# Sparrow SMS
# https://docs.sparrowsms.com/
# SPARROW_SMS_TOKEN="your_sparrow_sms_token"
# SPARROW_SMS_FROM="Utsav"

# =============================================================================
# Email Service
# =============================================================================

# SendGrid
# https://sendgrid.com/docs/
# SENDGRID_API_KEY="your_sendgrid_api_key"

# SMTP Settings (alternative to SendGrid)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="your_smtp_user"
# SMTP_PASSWORD="your_smtp_password"
# SMTP_FROM="noreply@utsav.com.np"

# =============================================================================
# Push Notifications
# =============================================================================

# Firebase Cloud Messaging
# https://firebase.google.com/docs/cloud-messaging
# FCM_SERVER_KEY="your_fcm_server_key"
# FCM_SENDER_ID="your_fcm_sender_id"

# =============================================================================
# Redis Configuration (Rate Limiting, Caching)
# =============================================================================

# Redis connection for rate limiting and session storage
# REDIS_HOST="localhost"
# REDIS_PORT="6379"
# REDIS_PASSWORD=""
# REDIS_DB="0"
# REDIS_URL="redis://localhost:6379"