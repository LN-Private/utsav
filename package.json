{
  "name": "utsav",
  "version": "1.0.0",
  "private": true,
  "description": "Nepal's First Ceremony Service Marketplace",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev -w @utsav/api",
    "dev:web": "npm run dev -w @utsav/web",
    "build": "npm run build -w @utsav/shared && npm run build -w @utsav/api && npm run build -w @utsav/web",
    "build:api": "npm run build -w @utsav/api",
    "build:web": "npm run build -w @utsav/web",
    "lint": "eslint .",
    "typecheck": "npm run typecheck -w @utsav/api && npm run typecheck -w @utsav/web"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}